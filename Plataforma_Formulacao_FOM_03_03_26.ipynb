class BancoDeDados:
    def __init__(self, nome_arquivo="dados_agronomicos.db"):
        self.nome_arquivo = nome_arquivo
        self.conn = None
        
        if not os.path.exists(self.nome_arquivo):
            raise Exception(f"Ficheiro '{self.nome_arquivo}' não encontrado na pasta.")
            
        self.conectar()

    def conectar(self):
        try:
            self.conn = sqlite3.connect(self.nome_arquivo)
            self.cursor = self.conn.cursor()
        except sqlite3.OperationalError as e:
            raise Exception(f"Erro ao conectar à base de dados: {e}")

    def checar_mistura(self, codigo_a, codigo_b):
        if not codigo_a or not codigo_b:
            return 'Sem Estudo'
        try:
            query = "SELECT status FROM matriz_compatibilidade WHERE codigo_a = ? AND codigo_b = ?"
            self.cursor.execute(query, (str(codigo_a), str(codigo_b)))
            resultado = self.cursor.fetchone()
            if resultado: return resultado[0] 
            
            self.cursor.execute(query, (str(codigo_b), str(codigo_a)))
            resultado = self.cursor.fetchone()
            if resultado: return resultado[0]
                
            return 'Sem Estudo'
        except sqlite3.Error:
            return 'Sem Estudo'

    def listar_culturas(self):
        self.cursor.execute("SELECT codigo, nome FROM culturas")
        return self.cursor.fetchall()
        
    def listar_cidades(self):
        try:
            self.cursor.execute("SELECT cidade FROM regime_chuvas ORDER BY cidade")
            return [row[0] for row in self.cursor.fetchall()]
        except Exception as e:
            print(f"[ERRO SQL - Cidades]: {e}")
            return []
            
    def buscar_clima_cidade(self, cidade):
        try:
            self.cursor.execute("SELECT jan, fev, mar, abr, mai, jun, jul, ago, sete, out, nov, dez FROM regime_chuvas WHERE cidade = ?", (cidade,))
            return self.cursor.fetchone()
        except Exception as e:
            print(f"[ERRO SQL - Clima]: {e}")
            return None

    def listar_fontes(self):
        self.cursor.execute("SELECT * FROM fontes")
        colunas = [desc[0] for desc in self.cursor.description]
        resultados = []
        for linha in self.cursor.fetchall():
            resultados.append(dict(zip(colunas, linha)))
        return resultados

    def buscar_dados_cultura(self, codigo):
        self.cursor.execute("SELECT id, nome, n_total, obs_n FROM culturas WHERE codigo=?", (codigo,))
        return self.cursor.fetchone()

    def buscar_recomendacao_faixa(self, cultura_id, nutriente, valor_solo):
        self.cursor.execute("SELECT dose_kgha FROM faixas_nutrientes WHERE cultura_id=? AND nutriente=? AND ? BETWEEN min_mg AND max_mg", (cultura_id, nutriente, valor_solo))
        res = self.cursor.fetchone()
        return res[0] if res else 0.0
    
    def fechar(self):
        self.conn.close()

# --- 2. MOTOR DE OTIMIZAÇÃO (SOLVER) ---

def otimizar_mistura(meta_n, meta_p, meta_k, fontes_disponiveis):
    if not TEM_SCIPY: return {'sucesso': False, 'msg': 'Biblioteca Scipy não instalada.'}
    if not fontes_disponiveis: return {'sucesso': False, 'msg': 'O lote está vazio.'}

    c = []
    A_ub = [[], [], []]
    b_ub = [-meta_n, -meta_p, -meta_k] 
    idx_org, idx_min = [], []
    
    for i, f in enumerate(fontes_disponiveis):
        custo_val = f.get('custo_kg') if f.get('custo_kg') is not None else 0.01 
        c.append(custo_val)
        A_ub[0].append(-( float(f.get('n_perc') or 0.0)/100.0 ))
        A_ub[1].append(-( float(f.get('p_perc') or 0.0)/100.0 ))
        A_ub[2].append(-( float(f.get('k_perc') or 0.0)/100.0 ))
        
        tipo_raw = str(f.get('tipo', '')).lower()
        if 'mineral' in tipo_raw or 'quimico' in tipo_raw: idx_min.append(i)
        else: idx_org.append(i)

    def tentar_resolver(min_org_frac, min_inc_frac):
        A_temp, b_temp = [row[:] for row in A_ub], b_ub[:]
        if idx_org and idx_min and min_org_frac > 0:
            row_org = [min_org_frac] * len(fontes_disponiveis)
            for i in idx_org: row_org[i] = -(1.0 - min_org_frac)
            A_temp.append(row_org); b_temp.append(0.0)
        if min_inc_frac > 0:
            for i in range(len(fontes_disponiveis)):
                row_inc = [min_inc_frac] * len(fontes_disponiveis); row_inc[i] = min_inc_frac - 1.0
                A_temp.append(row_inc); b_temp.append(0.0)
        bounds = [(0, None) for _ in range(len(fontes_disponiveis))]
        return linprog(c, A_ub=A_temp, b_ub=b_temp, bounds=bounds, method='highs')

    res = tentar_resolver(0.50, 0.01)
    if not res.success: res = tentar_resolver(0.25, 0.01)
    if not res.success: res = tentar_resolver(0.0, 0.01)
    if not res.success: res = tentar_resolver(0.0, 0.0)

    if res.success:
        ingredientes_info = []
        peso_total_ha = sum(res.x)
        if peso_total_ha == 0: return {'sucesso': False, 'msg': 'Demanda já atendida pelo solo.'}
        
        for i, qtd_ha in enumerate(res.x):
            if qtd_ha > 0.001:
                f = fontes_disponiveis[i]
                perc = (qtd_ha / peso_total_ha) * 100
                ingredientes_info.append({
                    'nome': f.get('nome', 'Desconhecido'),
                    'kg_ha': qtd_ha,
                    'perc': perc,
                    'massa_em_1000kg': (perc * 10),
                    'tipo': f.get('tipo', ''),
                    'codigo_fonte': f.get('codigo_fonte', '')
                })
        
        n_forn = sum([(float(f.get('n_perc') or 0.0)) * res.x[i] / 100 for i, f in enumerate(fontes_disponiveis)])
        p_forn = sum([(float(f.get('p_perc') or 0.0)) * res.x[i] / 100 for i, f in enumerate(fontes_disponiveis)])
        k_forn = sum([(float(f.get('k_perc') or 0.0)) * res.x[i] / 100 for i, f in enumerate(fontes_disponiveis)])
        
        n_conc = (n_forn/peso_total_ha*100) if peso_total_ha > 0 else 0
        p_conc = (p_forn/peso_total_ha*100) if peso_total_ha > 0 else 0
        k_conc = (k_forn/peso_total_ha*100) if peso_total_ha > 0 else 0
        
        extras = {}
        for i, f in enumerate(fontes_disponiveis):
            for chave, valor in f.items():
                if isinstance(chave, str) and chave.endswith('_perc') and chave not in ['n_perc', 'p_perc', 'k_perc']:
                    if chave not in extras:
                        extras[chave] = {'fornecido': 0.0}
                    val = 0.0
                    if valor is not None:
                        try:
                            v_str = str(valor).replace(',', '.').strip()
                            val = float(v_str) if v_str else 0.0
                        except ValueError:
                            val = 0.0
                    extras[chave]['fornecido'] += (val * res.x[i] / 100.0)

        for k in extras:
            extras[k]['concentracao'] = (extras[k]['fornecido'] / peso_total_ha * 100.0) if peso_total_ha > 0 else 0.0

        return {
            'sucesso': True,
            'ingredientes': ingredientes_info,
            'peso_total_ha': peso_total_ha,
            'n_forn': n_forn, 'p_forn': p_forn, 'k_forn': k_forn,
            'n_conc': n_conc, 'p_conc': p_conc, 'k_conc': k_conc,
            'extras': extras
        }
    return {'sucesso': False, 'msg': 'Não foi possível equilibrar a mistura com as fontes selecionadas.'}

