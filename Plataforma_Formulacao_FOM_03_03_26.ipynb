    def criar_arvore(self, p, mapa, h=6):
        t = ttk.Treeview(p, columns=("N", "P", "K"), show="tree headings", height=h)
        t.heading("#0", text="Nome"); t.column("#0", width=130)
        for c in ("N", "P", "K"): t.heading(c, text=c+"%"); t.column(c, width=35, anchor="center")
        t.pack(fill="both", expand=True)
        for n, f in sorted(mapa.items()): 
            t.insert("", "end", text=n, values=(f.get('n_perc') or 0, f.get('p_perc') or 0, f.get('k_perc') or 0))
        return t

    def add_f(self):
        aba = self.nb.index(self.nb.select())
        orig, mapa = (self.tree_min, self.map_fontes_min) if aba == 0 else (self.tree_org, self.map_fontes_org)
        for i in orig.selection():
            n = orig.item(i)['text']; f = mapa[n]
            if any(n == self.tree_c.item(c)['text'] for c in self.tree_c.get_children()): continue
            self.tree_c.insert("", "end", text=n, values=(f.get('n_perc') or 0, f.get('p_perc') or 0, f.get('k_perc') or 0))
            self.carrinho.append(f)

    def rem_f(self):
        for i in self.tree_c.selection():
            n = self.tree_c.item(i)['text']
            self.carrinho = [f for f in self.carrinho if f.get('nome') != n]
            self.tree_c.delete(i)

    def calcular_janela_climatica(self, chuvas):
        """Identifica os 3 meses mais secos (produção ideal) e os 3 mais chuvosos."""
        meses = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez']
        
        # Calcula as somas de chuva em blocos de 3 meses deslizantes
        somas_3m = []
        for i in range(12):
            if i <= 9:
                soma = sum(chuvas[i:i+3])
            else:
                soma = sum(chuvas[i:]) + sum(chuvas[:(i+3)%12]) # Circular (ex: Nov, Dez, Jan)
            somas_3m.append(soma)
            
        min_idx = somas_3m.index(min(somas_3m))
        max_idx = somas_3m.index(max(somas_3m))
        
        melhor_inicio = meses[min_idx]
        melhor_fim = meses[(min_idx+2)%12]
        
        pior_inicio = meses[max_idx]
        pior_fim = meses[(max_idx+2)%12]
        
        return melhor_inicio, melhor_fim, pior_inicio, pior_fim

    def mostrar_grafico_clima(self):
        if not TEM_MATPLOTLIB:
            messagebox.showinfo("Aviso", "Instale a biblioteca matplotlib para ver o gráfico (pip install matplotlib).")
            return
            
        if not self.dados_chuva_atual:
            return
            
        top = tk.Toplevel(self)
        top.title(f"Regime de Chuvas - {self.cidade_atual}")
        top.geometry("650x450")
        
        fig, ax = plt.subplots(figsize=(6, 4))
        meses = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez']
        
        # Criar o gráfico de barras
        barras = ax.bar(meses, self.dados_chuva_atual, color='#4A90E2', edgecolor='#2171C7')
        
        ax.set_title(f"Precipitação Média Mensal - {self.cidade_atual}", fontsize=14, pad=15)
        ax.set_ylabel("Precipitação (mm)", fontsize=10)
        ax.set_xlabel("Meses do Ano", fontsize=10)
        
        # Adicionar o número em cima de cada barra
        for barra in barras:
            altura = barra.get_height()
            ax.annotate(f'{int(altura)}',
                        xy=(barra.get_x() + barra.get_width() / 2, altura),
                        xytext=(0, 3),  # 3 pontos de offset vertical
                        textcoords="offset points",
                        ha='center', va='bottom', fontsize=9)
        
        # Desenhar no Tkinter
        canvas = FigureCanvasTkAgg(fig, master=top)
        canvas.draw()
        canvas.get_tk_widget().pack(fill=tk.BOTH, expand=True, padx=10, pady=10)

    def calcular(self):
        try:
            self.out.delete(1.0, "end")
            s_p, s_k, area = float(self.vars_solo['P'].get()), float(self.vars_solo['K_mg'].get()), float(self.var_ha.get())
            c_raw = self.var_cult.get()
            self.cidade_atual = self.var_cidade.get()
            
            if not c_raw or not self.carrinho:
                self.out.insert("end", "[!] Selecione a cultura e adicione insumos ao lote.\n")
                return
            
            d_c = self.db.buscar_dados_cultura(c_raw.split(" - ")[0])
            m_n, m_p, m_k = (d_c[2] or 0), self.db.buscar_recomendacao_faixa(d_c[0], 'P', s_p), self.db.buscar_recomendacao_faixa(d_c[0], 'K', s_k)

            res = otimizar_mistura(m_n, m_p, m_k, self.carrinho)
            
            if res['sucesso']:
                self.out.insert("end", "="*65 + "\n RELATÓRIO DE FORMULAÇÃO ORGANOMINERAL\n" + "="*65 + "\n\n")
                self.out.insert("end", f"DEMANDA DA CULTURA ({d_c[1]}):\n N: {m_n:.1f} | P2O5: {m_p:.1f} | K2O: {m_k:.1f} kg/ha\n\n")

                self.out.insert("end", "RECEITA PARA UM LOTE DE 1000 kg (1 Tonelada):\n")
                self.out.insert("end", f"{'Ingrediente':<25} | {'% Lote':<8} | {'Massa (kg)'} | {'Aplicação'}\n" + "-"*75 + "\n")
                for it in sorted(res['ingredientes'], key=lambda x: str(x.get('tipo')), reverse=True):
                    self.out.insert("end", f" {it['nome'][:24]:<25} | {it['perc']:>7.2f}% | {it['massa_em_1000kg']:>8.2f} kg | {it['kg_ha']:>7.2f} kg/ha\n")
                self.out.insert("end", "-"*75 + f"\n {'TOTAL DA MISTURA':<25} | 100.00%  | 1000.00 kg | {res['peso_total_ha']:.2f} kg/ha\n\n")

                n_int, p_int, k_int = int(round(m_n)), int(round(m_p)), int(round(m_k))
                mdc = math.gcd(math.gcd(n_int, p_int), k_int)
                rel_n, rel_p, rel_k = (n_int // mdc, p_int // mdc, k_int // mdc) if mdc > 0 else (0, 0, 0)
                
                gar_n, gar_p, gar_k = int(round(res['n_conc'])), int(round(res['p_conc'])), int(round(res['k_conc']))

                self.out.insert("end", "="*65 + "\n ESPECIFICAÇÃO DO PRODUTO (RELAÇÃO NPK)\n" + "="*65 + "\n")
                self.out.insert("end", f" RELAÇÃO NPK (Proporção Agronómica):  {rel_n:02d}-{rel_p:02d}-{rel_k:02d}\n")
                self.out.insert("end", f" GARANTIAS MÍNIMAS (Teor % no Saco):  {gar_n:02d}-{gar_p:02d}-{gar_k:02d}\n\n")

                self.out.insert("end", "GARANTIAS EXTRAS DETECTADAS NO LOTE (Macro/Micronutrientes):\n")
                tem_extra = False
                nomes_bonitos = { "MO": "MAT. ORGÂNICA", "C": "CARBONO (C.O.)", "CA": "CÁLCIO (Ca)", "MG": "MAGNÉSIO (Mg)", "S": "ENXOFRE (S)", "B": "BORO (B)", "CO": "COBALTO (Co)", "CU": "COBRE (Cu)", "FE": "FERRO (Fe)", "MN": "MANGANÊS (Mn)", "NI": "NÍQUEL (Ni)", "ZN": "ZINCO (Zn)", "SI": "SILÍCIO (Si)", "SE": "SELÊNIO (Se)"}
                
                for chave_nutriente in sorted(res['extras'].keys()):
                    dados_nutriente = res['extras'][chave_nutriente]
                    if dados_nutriente['concentracao'] > 0.0:
                        tem_extra = True
                        nome_cru = chave_nutriente.replace('_perc', '').upper()
                        nome_amigavel = nomes_bonitos.get(nome_cru, nome_cru)
                        self.out.insert("end", f" > {nome_amigavel:<16}: {dados_nutriente['concentracao']:>8.4f}% no saco (Fornece {dados_nutriente['fornecido']:>7.4f} kg/ha ao solo)\n")
                if not tem_extra: self.out.insert("end", " > Nenhuma garantia secundária ou micronutriente detetada na mistura.\n")

                soma_npk = res['n_conc'] + res['p_conc'] + res['k_conc']
                co_perc = res['extras'].get('c_perc', {}).get('concentracao', 0.0)

                self.out.insert("end", "\n" + "="*65 + "\n VALIDAÇÃO LEGISLAÇÃO MAPA E CLIMA\n" + "="*65 + "\n")
                self.out.insert("end", f" [✓] SOMA NPK >= 10% ({soma_npk:.1f}%)\n" if soma_npk >= 10 else f" [X] SOMA NPK >= 10% ({soma_npk:.1f}%) -> REPROVADO\n")
                self.out.insert("end", f" [✓] CARBONO (C.O.) >= 8% ({co_perc:.1f}%)\n" if co_perc >= 8 else f" [X] CARBONO (C.O.) >= 8% ({co_perc:.1f}%) -> REPROVADO\n")

                # --- ANÁLISE CLIMÁTICA (FASE 3) ---
                self.out.insert("end", "\n--- PLANEAMENTO DE PRODUÇÃO (CLIMA) ---\n")
                self.dados_chuva_atual = self.db.buscar_clima_cidade(self.cidade_atual)
                
                if self.dados_chuva_atual:
                    melhor_in, melhor_fim, pior_in, pior_fim = self.calcular_janela_climatica(self.dados_chuva_atual)
                    
                    self.out.insert("end", f" Localidade Base: {self.cidade_atual.upper()}\n")
                    self.out.insert("end", f" [✓] MELHOR ÉPOCA (Seca): A melhor janela para a produção e secagem\n")
                    self.out.insert("end", f"     deste lote é entre {melhor_in} e {melhor_fim}, devido ao menor índice de chuvas.\n")
                    
                    self.out.insert("end", f" [X] PIOR ÉPOCA (Chuva): Evite produzir compostos a céu aberto\n")
                    self.out.insert("end", f"     entre {pior_in} e {pior_fim}.\n")
                    
                    # Habilita o botão para o gráfico
                    self.btn_grafico.config(state=tk.NORMAL)
                else:
                    self.out.insert("end", f" Não existem dados pluviométricos cadastrados para '{self.cidade_atual}'.\n")
                    self.btn_grafico.config(state=tk.DISABLED)

                # --- ANÁLISE DE COMPATIBILIDADE ---
                self.out.insert("end", "\nANÁLISE DE COMPATIBILIDADE QUÍMICA:\n")
                alertas, ing = [], res['ingredientes']
                for i in range(len(ing)):
                    for j in range(i + 1, len(ing)):
                        st = self.db.checar_mistura(ing[i]['codigo_fonte'], ing[j]['codigo_fonte'])
                        if st == "I": alertas.append(f" [!] INCOMPATÍVEL: {ing[i]['nome']} + {ing[j]['nome']}")
                        elif st == "L": alertas.append(f" [?] LIMITADO: {ing[i]['nome']} + {ing[j]['nome']} (Misturar no ato)")
                
                if not alertas: self.out.insert("end", " ✅ Todos os componentes selecionados são compatíveis.\n")
                else: 
                    for a in alertas: self.out.insert("end", f"{a}\n")

            else:
                self.out.insert("end", f"[FALHA] {res['msg']}\n")
            
            self.out.insert("end", "\n" + "-"*65 + "\n Sempre consulte um Engenheiro Agrônomo.\n")
        except Exception as e:
            self.out.insert("end", f"[ERRO] {str(e)}\n{traceback.format_exc()}")

if __name__ == "__main__":
    try:
        db = BancoDeDados(); AppFormulacao(db).mainloop()
    except Exception as e:
        print(f"Erro fatal: {e}"); traceback.print_exc()
